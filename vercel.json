{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.life-cycle-manager.vercel.app" }],
      "destination": "https://life-cycle-manager.vercel.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/airtable", "destination": "/api/airtable" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
